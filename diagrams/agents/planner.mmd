flowchart TD
  s([Trigger · pg_cron 25th 06:30 IST<br/>or manual Run Planner now]):::start

  subgraph P1[Phase 1 · month-end analysis · Modal graphs/planner.py]
    e1[planner-cron Edge Fn · x-cron-secret<br/>POST /run/planner per pilot sub]:::edge
    a1[fetch · month window per sub<br/>goals plan · worklogs/tasks execution<br/>digests · weekly summaries · moms · kpis]:::proc
    a2[analyze · memoryFor Planner + fence<br/>complete_json &rarr; PlannerOut<br/>diff · findings · questions · draft goals]:::model
    d1{cites all real?}:::dec
    r1[drop bad cites · retry once]:::stop
    e1 --> a1 --> a2 --> d1
    d1 -- no --> r1 --> a2
  end
  s --> e1

  rd[(roadmap_drafts · DRAFT<br/>+ ai_runs + activity ping)]:::store
  d1 -- yes --> rd

  subgraph P2[Phase 2 · L2 conversation · Concierge]
    c1[Roadmap category chip<br/>PLANNING block in system prompt]:::proc
    c2[structured Q&A<br/>agent asks · L2 answers / edits]:::model
    c3[confirm-gated ActionCard<br/>update_roadmap_draft]:::proc
    c1 --> c2 --> c3
    c3 -. more edits .-> c2
  end
  rd --> c1

  d2{L2 finalizes?}:::dec
  c3 --> d2
  d2 -- not yet --> c2
  fin[finalize_roadmap · status FINAL<br/>RLS app.sub_in_scope]:::proc
  d2 -- yes --> fin

  g[(goals · next-month rows)]:::store
  fin --> g

  en[(engram_interactions<br/>L2 edits &rarr; Curator &rarr; Planner memory)]:::store
  c3 -.-> en
  en -.-> a2

  loop([next month's execution &rarr; worklogs/digests/moms<br/>ground the next cycle · LOOP CLOSED]):::start
  g --> loop

