flowchart TD
  s([Trigger · MOM Loader · paste transcript]):::start
  d1{transcript length &gt; 20<br/>and agents available?}:::dec
  s --> d1

  subgraph P1[Phase 1 · prompt assembly]
    a1[Build roster<br/>USERS &rarr; name — level — sub]:::proc
    a2[Build prompt<br/>4 outputs + 1-shot example<br/>+ transcript]:::proc
    a1 --> a2
  end
  d1 -- yes --> a1

  subgraph P2[Phase 2 · run core]
    b1[memoryFor Scribe<br/>inject Curator rules]:::proc
    b2[askAgent model=smart]:::proc
    b3[Edge Function relay-agent<br/>JWT · OPENROUTER_API_KEY]:::edge
    b4[OpenRouter &rarr; Claude Sonnet 4.6]:::model
    b5[log ai_runs + activity]:::proc
    b1 --> b2 --> b3 --> b4
    b2 -.-> b5
  end
  a2 --> b1

  subgraph P3[Phase 3 · parse + normalize]
    c1[regex match curly &rarr; JSON.parse]:::proc
    d2{parse ok?}:::dec
    c2[normalize summary 3 lenses<br/>attendees · items]:::proc
    c1 --> d2
    d2 -- yes --> c2
  end
  b4 --> c1

  out([Return agenda · attendees<br/>summary · items]):::start
  c2 --> out

  fb[Fallback · extractFromTranscript<br/>or canned demo items]:::stop
  d1 -- no --> fb
  d2 -- no --> fb

  disp[Dispatcher · code · 5-tier route<br/>assigneeHint &rarr; employee]:::proc
  rev[Human review &rarr; commit]:::proc
  tasks[(tasks + engram_interactions)]:::store
  out --> disp --> rev --> tasks
  fb --> disp

