flowchart TD
  t1([Auto-trigger · 5 corrections<br/>for an agent]):::start
  t2([Manual / scheduled pass]):::start

  subgraph P1[Phase 1 · gather + group]
    a1[ENGRAM.filter action != accept<br/>only edits / rejects teach]:::proc
    a2[group by e.agent &rarr; byAgent]:::proc
    a1 --> a2
  end
  t1 --> a1
  t2 --> a1

  loop{{for each agent group}}:::dec
  a2 --> loop

  subgraph P2[Phase 2 · distill per agent]
    b0[build cases · up to 40<br/>AI draft vs human-kept vs reason]:::proc
    b1[prompt · find recurring corrections<br/>&rarr; 3-7 imperative rules]:::proc
    b2[memoryFor Curator &rarr; askAgent smart]:::proc
    b3[Edge Function relay-agent · JWT]:::edge
    b4[OpenRouter &rarr; Claude Sonnet 4.6]:::model
    b5[regex curly &rarr; JSON.parse &rarr; .rules]:::proc
    d1{parse ok and rules?}:::dec
    b0 --> b1 --> b2 --> b3 --> b4 --> b5 --> d1
  end
  loop --> b0

  skip[skip this agent · continue]:::stop
  d1 -- no --> skip

  write[Write relay_agents.data.memory<br/>rules · distilledFrom · ts<br/>local + remote update]:::store
  d1 -- yes --> write

  inject[memoryFor injects rules<br/>into that agent's NEXT run]:::proc
  selfcorrect([Producers self-correct<br/>LOOP CLOSED]):::start
  write --> inject --> selfcorrect

